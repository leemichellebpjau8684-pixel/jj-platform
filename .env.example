# =====================================================
# 家教中介平台 - 环境变量示例
# =====================================================
# 复制此文件为 .env 并填入实际值
# 生产环境环境变量请在 Netlify Dashboard（前端）和 Railway（后端）设置

# =====================================================
# 前端环境变量（Netlify 配置）
# =====================================================
# API 地址：前端调用后端API的完整URL
# 开发环境通常为：http://localhost:3001
# 生产环境为后端部署地址，如：https://xxx.up.railway.app
VITE_API_URL=http://localhost:3001

# 高德地图 JavaScript API 密钥（前端地图显示使用）
# 在高德地图开发者平台申请：https://console.amap.com/
VITE_AMAP_JS_KEY=your_amap_js_api_key

# 高德地图安全密钥（前端安全验证）
# 在高德地图开发者平台的安全密钥配置中获取
VITE_AMAP_JS_SECURITY_CODE=your_amap_js_security_code

# =====================================================
# 后端环境变量（Railway 配置）
# =====================================================

# 数据库配置（PostgreSQL）
# 格式: postgresql://username:password@host:port/database
DATABASE_URL=

# JWT 配置（至少32个字符的随机字符串）
# 用于生成和验证管理员登录令牌
JWT_SECRET=your_jwt_secret_key_min_32_characters_long

# 管理员密码（登录管理后台使用）
# 用户名固定为: admin
ADMIN_PASSWORD=your_secure_admin_password

# 高德地图 Web 服务密钥（地理编码专用）
# 用于将地址转换为经纬度坐标
AMAP_WEB_KEY=your_amap_web_api_key
AMAP_SECURITY_CODE=your_amap_security_code

# =====================================================
# Node 环境
# =====================================================
NODE_ENV=development
# NODE_ENV=production
